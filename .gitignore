# Secrets — never commit
.env

# Local enrollment data
voiceprint.npy

# Models (large; download per README)
models/
pretrained/

# Embedded Qdrant stores (memory + documents)
qdrant_data/
qdrant_docs/

# Your personal documents for RAG
docs/

# Python
.venv/
.venv-crew/
.venv-train/
__pycache__/

# CrewAI coding-agent outputs
crew_output/
*.pyc

# Scratch audio
*.wav

# Screenshots + webcam photos captured via system control
screenshots/
photos/

# Meeting recordings/notes
meetings/

# Enrolled face embeddings (biometric data — keep local)
faces.npz

# Startup password hash (keep local)
auth_secret.dat

# Wake-word training (PyTorch): GPU venv + data/features/model artifacts.
# Source scripts in wake_pytorch/ ARE tracked; only the heavy outputs are ignored.
wake_pytorch/.venv/
wake_pytorch/data/
wake_pytorch/features/
wake_pytorch/checkpoints/
wake_pytorch/*.pt
wake_pytorch/*.onnx
# ...except the exported runtime wake-word model, which ships in-repo.
!wake_pytorch/atlas.onnx

.vscode/
# face window crash log
face_window.log

# registered users (names + authority)
users.json

# per-user voiceprints
voiceprints/

# sample-generation venv (GPU torch + piper)
.venv-gen/
